msgid "Colony event"
msgstr "殖民地事件"

msgctxt "STRINGS.ONITALK.CORE.MEMORY_PREVIEW.KIND_MEMORY"
msgid "Memory"
msgstr "记忆"

msgctxt "STRINGS.ONITALK.OPTIONS.ENABLED.NAME"
msgid "Enable ONITalk"
msgstr "启用 ONITalk"

msgctxt "STRINGS.ONITALK.OPTIONS.ENABLED.TOOLTIP"
msgid "When disabled, ONITalk will not generate any new dialogue."
msgstr "关闭后不会再生成任何新台词。"

msgctxt "STRINGS.ONITALK.OPTIONS.PROVIDER_CONFIGURATION.NAME"
msgid "Provider configuration"
msgstr "服务商配置"

msgctxt "STRINGS.ONITALK.OPTIONS.PROVIDER_CONFIGURATION.TOOLTIP"
msgid "Choose a common provider or enter a custom OpenAI-compatible endpoint."
msgstr "选择常用服务商，或填写自定义 OpenAI-Compatible 接口。"

msgctxt "STRINGS.ONITALK.OPTIONS.AMBIENT_CHATTER_INTERVAL_SECONDS.NAME"
msgid "Ambient chatter interval (seconds)"
msgstr "普通闲聊间隔（秒）"

msgctxt "STRINGS.ONITALK.OPTIONS.AMBIENT_CHATTER_INTERVAL_SECONDS.TOOLTIP"
msgid "How often nearby Duplicants may chat when there is no urgent condition."
msgstr "没有紧急状态时，附近复制人之间产生闲聊的间隔。"

msgctxt "STRINGS.ONITALK.OPTIONS.PAIR_COOLDOWN_SECONDS.NAME"
msgid "Duplicant pair cooldown (seconds)"
msgstr "同一对复制人冷却（秒）"

msgctxt "STRINGS.ONITALK.OPTIONS.PAIR_COOLDOWN_SECONDS.TOOLTIP"
msgid "Minimum wait before the same pair of Duplicants can talk again."
msgstr "同一对复制人再次对话前至少等待多久。"

msgctxt "STRINGS.ONITALK.OPTIONS.GLOBAL_COOLDOWN_SECONDS.NAME"
msgid "Global cooldown (seconds)"
msgstr "全局冷却（秒）"

msgctxt "STRINGS.ONITALK.OPTIONS.GLOBAL_COOLDOWN_SECONDS.TOOLTIP"
msgid "Minimum interval between any two ONITalk lines in the colony."
msgstr "整个殖民地两句 ONITalk 台词之间的最短间隔。"

msgctxt "STRINGS.ONITALK.OPTIONS.CONVERSATION_REPLIES_ENABLED.NAME"
msgid "Allow listener replies"
msgstr "允许听者回应"

msgctxt "STRINGS.ONITALK.OPTIONS.CONVERSATION_REPLIES_ENABLED.TOOLTIP"
msgid "Allows the listener to reply after an opening line. This can increase API usage."
msgstr "开启后，一次触发可以继续生成听者回复；会增加 API 调用次数。"

msgctxt "STRINGS.ONITALK.OPTIONS.REPLY_CHANCE_PERCENT.NAME"
msgid "Listener reply chance (%)"
msgstr "听者回应概率（%）"

msgctxt "STRINGS.ONITALK.OPTIONS.REPLY_CHANCE_PERCENT.TOOLTIP"
msgid "Chance that an opening line develops into a continued conversation."
msgstr "决定一条起始台词是否发展为连续对话。"

msgctxt "STRINGS.ONITALK.OPTIONS.MAX_CONVERSATION_LINES.NAME"
msgid "Maximum lines per conversation"
msgstr "每次对话最多台词数"

msgctxt "STRINGS.ONITALK.OPTIONS.MAX_CONVERSATION_LINES.TOOLTIP"
msgid "Includes the opening line. A value of 2 means one opening line and one reply."
msgstr "包含第一句；设为 2 时是说话者一句、听者回应一句。"

msgctxt "STRINGS.ONITALK.OPTIONS.REPLY_DELAY_SECONDS.NAME"
msgid "Reply delay (seconds)"
msgstr "回应间隔（秒）"

msgctxt "STRINGS.ONITALK.OPTIONS.REPLY_DELAY_SECONDS.TOOLTIP"
msgid "How long the listener waits before replying to the previous line."
msgstr "上一句显示后，听者等待多久再回应。"

msgctxt "STRINGS.ONITALK.OPTIONS.TESTING_MODE.NAME"
msgid "High-frequency testing mode"
msgstr "高频测试模式"

msgctxt "STRINGS.ONITALK.OPTIONS.TESTING_MODE.TOOLTIP"
msgid "For testing only. This greatly increases dialogue and API request frequency."
msgstr "仅用于测试；会明显增加台词和 API 调用频率。"

msgctxt "STRINGS.ONITALK.OPTIONS.TESTING_CHATTER_INTERVAL_SECONDS.NAME"
msgid "Testing chatter interval (seconds)"
msgstr "测试闲聊间隔（秒）"

msgctxt "STRINGS.ONITALK.OPTIONS.TESTING_CHATTER_INTERVAL_SECONDS.TOOLTIP"
msgid "Used only while high-frequency testing mode is enabled."
msgstr "仅在高频测试模式开启时使用。"

msgctxt "STRINGS.ONITALK.OPTIONS.MAX_CONVERSATION_DISTANCE.NAME"
msgid "Maximum conversation distance"
msgstr "最大交谈距离"

msgctxt "STRINGS.ONITALK.OPTIONS.MAX_CONVERSATION_DISTANCE.TOOLTIP"
msgid "Only Duplicants within this distance can talk to each other."
msgstr "只让这个距离以内的复制人互相说话。"

msgctxt "STRINGS.ONITALK.OPTIONS.REQUEST_TIMEOUT_SECONDS.NAME"
msgid "API timeout (seconds)"
msgstr "API 超时（秒）"

msgctxt "STRINGS.ONITALK.OPTIONS.REQUEST_TIMEOUT_SECONDS.TOOLTIP"
msgid "Cancels a request after this duration and uses offline dialogue instead."
msgstr "超过该时间会取消请求并改用离线台词。"

msgctxt "STRINGS.ONITALK.OPTIONS.TEMPERATURE.NAME"
msgid "Dialogue randomness"
msgstr "台词随机度"

msgctxt "STRINGS.ONITALK.OPTIONS.TEMPERATURE.TOOLTIP"
msgid "Higher values produce more varied dialogue. The valid range depends on the provider."
msgstr "值越高台词越活泼；可用范围取决于当前服务商。"

msgctxt "STRINGS.ONITALK.OPTIONS.MAX_CHARACTERS.NAME"
msgid "Maximum characters per line"
msgstr "单句最大字符数"

msgctxt "STRINGS.ONITALK.OPTIONS.MAX_CHARACTERS.TOOLTIP"
msgid "Generated speech-bubble text is limited to this length."
msgstr "生成后的气泡文本会被限制在这个长度以内。"

msgctxt "STRINGS.ONITALK.OPTIONS.MAX_TOKENS.NAME"
msgid "Maximum API output tokens"
msgstr "API 最大输出 Token"

msgctxt "STRINGS.ONITALK.OPTIONS.MAX_TOKENS.TOOLTIP"
msgid "Short dialogue usually does not need a large output limit."
msgstr "短台词通常不需要很高的输出上限。"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_WINDOW_ENABLED.NAME"
msgid "Show chat history window"
msgstr "显示聊天历史窗口"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_WINDOW_ENABLED.TOOLTIP"
msgid "Continuously displays ONITalk conversation history in the game interface."
msgstr "在游戏界面持续显示 ONITalk 对话历史。"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_HISTORY_LIMIT.NAME"
msgid "Chat history limit"
msgstr "历史消息上限"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_HISTORY_LIMIT.TOOLTIP"
msgid "Keeps only the newest messages to limit memory usage during long games."
msgstr "只保留最新的若干条消息，避免长期游戏占用过多内存。"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_FONT_SIZE.NAME"
msgid "Chat font size"
msgstr "聊天字体大小"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_FONT_SIZE.TOOLTIP"
msgid "Adjusts dialogue text size inside the history window."
msgstr "调整历史窗口内的台词字号。"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_WINDOW_OPACITY.NAME"
msgid "Window background opacity"
msgstr "窗口背景不透明度"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_WINDOW_OPACITY.TOOLTIP"
msgid "Lower values obstruct less of the game view. Text and buttons remain visible."
msgstr "数值越低越不挡视野；文字和按钮不会一起变淡。"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_WINDOW_AUTO_FADE.NAME"
msgid "Darken background on hover"
msgstr "鼠标悬停时加深背景"

msgctxt "STRINGS.ONITALK.OPTIONS.CHAT_WINDOW_AUTO_FADE.TOOLTIP"
msgid "Increases background opacity while the pointer is over the window."
msgstr "鼠标移入窗口时自动提高背景不透明度，移开后恢复。"

msgctxt "STRINGS.ONITALK.OPTIONS.PERSISTENT_MEMORY_ENABLED.NAME"
msgid "Enable long-term colony memory"
msgstr "启用殖民地长期记忆"

msgctxt "STRINGS.ONITALK.OPTIONS.PERSISTENT_MEMORY_ENABLED.TOOLTIP"
msgid "Stores recent conversations and familiarity per colony. Different saves never share memory."
msgstr "按殖民地保存复制人之间的近期对话和熟悉程度；不同存档不会混用。"

msgctxt "STRINGS.ONITALK.OPTIONS.MEMORY_LINES_PER_PAIR.NAME"
msgid "Memory lines per Duplicant pair"
msgstr "每对复制人记忆条数"

msgctxt "STRINGS.ONITALK.OPTIONS.MEMORY_LINES_PER_PAIR.TOOLTIP"
msgid "Number of recent shared lines available to dialogue generation."
msgstr "送入台词提示词的最近共同对话数量。"

msgctxt "STRINGS.ONITALK.OPTIONS.MEMORY_MAX_PAIRS.NAME"
msgid "Maximum stored relationships"
msgstr "最多保存关系数"

msgctxt "STRINGS.ONITALK.OPTIONS.MEMORY_MAX_PAIRS.TOOLTIP"
msgid "Limits the colony memory file size by removing the least recently updated relationships."
msgstr "限制殖民地关系记忆文件大小；超过后移除最久未更新的关系。"

msgctxt "STRINGS.ONITALK.OPTIONS.ACTION_MEMORY_ENABLED.NAME"
msgid "Enable action memory"
msgstr "启用行动记忆"

msgctxt "STRINGS.ONITALK.OPTIONS.ACTION_MEMORY_ENABLED.TOOLTIP"
msgid "Records important completed actions such as building, repair, digging, and fabrication."
msgstr "记录复制人已经完成的建造、修理、挖掘、制作等重要行动。"

msgctxt "STRINGS.ONITALK.OPTIONS.ACTION_MEMORY_CAPACITY_PER_DUPE.NAME"
msgid "Action memories per Duplicant"
msgstr "每人行动记忆上限"

msgctxt "STRINGS.ONITALK.OPTIONS.ACTION_MEMORY_CAPACITY_PER_DUPE.TOOLTIP"
msgid "Limits the number of local action records stored for each Duplicant."
msgstr "限制每位复制人的本地行动记录数量。"

msgctxt "STRINGS.ONITALK.OPTIONS.ACTION_AGGREGATION_WINDOW_CYCLES.NAME"
msgid "Repeated-action aggregation window"
msgstr "重复行动聚合周期"

msgctxt "STRINGS.ONITALK.OPTIONS.ACTION_AGGREGATION_WINDOW_CYCLES.TOOLTIP"
msgid "Repeated matching work within this many cycles is merged into one counted memory."
msgstr "在该周期范围内重复完成相同工作时，合并为一条计数记忆。"

msgctxt "STRINGS.ONITALK.OPTIONS.MAJOR_EVENT_MEMORY_ENABLED.NAME"
msgid "Enable major colony events"
msgstr "启用殖民地重大事件"

msgctxt "STRINGS.ONITALK.OPTIONS.MAJOR_EVENT_MEMORY_ENABLED.TOOLTIP"
msgid "Records confirmed colony events such as deaths and completed research."
msgstr "记录死亡和科技完成等经过游戏确认的殖民地事件。"

msgctxt "STRINGS.ONITALK.OPTIONS.MEMORY_PRESET.NAME"
msgid "Memory injection preset"
msgstr "记忆注入预设"

msgctxt "STRINGS.ONITALK.OPTIONS.MEMORY_PRESET.TOOLTIP"
msgid "Light uses about 250, Balanced 520, and Rich 850 tokens. Custom uses the budget below."
msgstr "轻量约 250、平衡约 520、丰富约 850 Token；自定义使用下方预算。"

msgctxt "STRINGS.ONITALK.OPTIONS.MEMORY_TOKEN_BUDGET.NAME"
msgid "Custom token budget"
msgstr "自定义 Token 预算"

msgctxt "STRINGS.ONITALK.OPTIONS.MEMORY_TOKEN_BUDGET.TOOLTIP"
msgid "Used only with the Custom preset. Limits memory text injected into each request."
msgstr "仅在预设选择“自定义”时生效；限制单次请求注入的记忆文本。"
